# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# OS and editor temp files
.DS_Store
*~
nul

# Ignore bundler config.
/.bundle

# Ignore all environment files except .env.example
/.env
/.env.*
!/.env.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore master key for decrypting credentials and more.
/config/master.key

/app/assets/builds/*
!/app/assets/builds/.keep

# Ignore local seed credentials
/config/seeds_credentials.yml

# Playwright
/**/node_modules/
/playwright-report/
/test-results/
/playwright/.cache/
/.auth/

# Devenv
.devenv*
devenv.local.nix
devenv.local.yaml

# direnv
.direnv

# pre-commit
.pre-commit-config.yaml
.playwright-mcp*
.playwright-cli*
.expect*

.claude/settings.local.json
# Ignore local Claude Code settings
/.claude/settings.local.json

# Ignore Windows batch scripts (local development utilities)
*.bat
.playwright.env
plans
html
